# Configuração do Banco de Dados Neon
# Copie este arquivo para .env e preencha com suas credenciais do Neon
# 
# Para obter a string de conexão:
# 1. Acesse https://console.neon.tech
# 2. Selecione seu projeto
# 3. Vá em "Connection Details"
# 4. Copie a connection string e cole abaixo

DATABASE_URL=postgresql://user:password@host.neon.tech/database?sslmode=require

# Chave secreta para JWT (gere uma chave segura em produção)
# Você pode gerar uma com: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=sua-chave-secreta-super-segura-aqui-mude-em-producao

# Log de queries SQL (True/False)
# Útil para debug, mas desabilite em produção
SQL_ECHO=False

